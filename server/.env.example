# ============================================================
# Tirth Sutra server environment variables
# Copy this file to server/.env and replace placeholders.
# Never commit real secrets.
# ============================================================

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/tirthsutra?retryWrites=true&w=majority

# Auth
JWT_SECRET=CHANGE_ME_use_a_long_random_string_at_least_32_chars
# Local development values:
CLIENT_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5000
SERVER_URL=http://localhost:5000
# Production example:
# CLIENT_URL=https://social-media-coral-tau.vercel.app
# FRONTEND_URL=https://social-media-coral-tau.vercel.app
# SERVER_URL=https://your-backend-domain.com
# Never keep these set to localhost in production.

# Google OAuth
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Add these in Google Cloud Console:
# Authorized redirect URIs:
#   http://localhost:5000/api/auth/google/callback
#   https://your-backend-domain.com/api/auth/google/callback

# SMTP / Nodemailer
# Gmail example for Tirth Sutra OTP signup emails:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tirthsutra@gmail.com
# SMTP_PASS=your_google_app_password
# EMAIL_FROM=tirthsutra@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tirthsutra@gmail.com
SMTP_PASS=your_google_app_password
EMAIL_FROM=tirthsutra@gmail.com
SMTP_VERIFY_ON_STARTUP=false
SMTP_VERIFY_BEFORE_SEND=false

# 1-year email drip campaign
# Sends only to users who tick the signup marketing checkbox.
EMAIL_CAMPAIGN_ENABLED=true
EMAIL_CAMPAIGN_PUBLIC_URL=https://your-backend-domain.com
EMAIL_CAMPAIGN_CLIENT_URL=https://your-frontend-domain.com
EMAIL_CAMPAIGN_DEFAULT_CTA_URL=https://shaleen17.github.io/Tirth-Sutra/
EMAIL_CAMPAIGN_SOCIAL_URL=https://shaleen17.github.io/Tirth-Sutra/
EMAIL_CAMPAIGN_MISSION_URL=https://shaleen17.github.io/Tirth-Sutra/
EMAIL_CAMPAIGN_SHOP_URL=https://shaleen17.github.io/Tirth-Sutra/
EMAIL_CAMPAIGN_BATCH_SIZE=25
EMAIL_CAMPAIGN_WORKER_INTERVAL_MS=300000
EMAIL_CAMPAIGN_START_DELAY_HOURS=24
EMAIL_CAMPAIGN_SEND_WINDOW_START=9
EMAIL_CAMPAIGN_SEND_WINDOW_END=18
EMAIL_CAMPAIGN_CRON_SECRET=CHANGE_ME_for_cron_endpoint
EMAIL_CAMPAIGN_ADMIN_KEY=CHANGE_ME_for_stats_endpoint

# Backward-compatible aliases if you prefer the old names
EMAIL_USER=tirthsutra@gmail.com
EMAIL_PASS=your_google_app_password

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay
# Use test keys in development and live keys in production only after activation.
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Web Push (optional but recommended for stable browser subscriptions)
# Generate once and keep them fixed in production.
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:your_email@example.com

# App
PORT=5000

# MyMemory Translation (used by the website language switcher)
# FREE — no installation, no API key required. Works on Render, Vercel, Railway etc.
# Optional: set your email below to raise the free daily limit from 5k to 10k words.
# Sign up (free) at https://mymemory.translated.net to get an email-linked quota.
# MYMEMORY_EMAIL=your_email@example.com

# Support inbox
SUPPORT_EMAIL=tirthsutra@gmail.com
